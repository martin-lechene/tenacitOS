# OpenClaw gateway — Node 22.12+ required by openclaw CLI
FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates git \
  && rm -rf /var/lib/apt/lists/* \
  && npm install -g openclaw@latest

COPY docker/openclaw-entrypoint.sh /entrypoint.sh
COPY docker/merge-whatsapp-channel.cjs /opt/merge-whatsapp-channel.cjs
COPY docker/sync-gateway-token.cjs /opt/sync-gateway-token.cjs
COPY docker/sync-agent-model.cjs /opt/sync-agent-model.cjs
COPY docker/merge-ollama-docker.cjs /opt/merge-ollama-docker.cjs
COPY docker/openclaw.bootstrap.json /opt/bootstrap/openclaw.json
COPY docker/workspace-IDENTITY.md /opt/bootstrap/IDENTITY.md
RUN chmod +x /entrypoint.sh

ENV HOME=/root
ENV OPENCLAW_DIR=/root/.openclaw
EXPOSE 18789
ENTRYPOINT ["/entrypoint.sh"]
