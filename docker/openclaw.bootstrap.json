{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://localhost:8119",
        "http://127.0.0.1:8119"
      ]
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://host.docker.internal:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "llama3.2:3b",
            "name": "Llama 3.2 3B (Ollama, léger)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 8192,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/llama3.2:3b"
      },
      "models": {
        "ollama/llama3.2:3b": { "alias": "Local (Ollama)" }
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Main Agent",
        "workspace": "/root/.openclaw/workspace"
      }
    ]
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": ["32496881898@s.whatsapp.net"],
      "groupAllowFrom": ["32496881898@s.whatsapp.net"]
    }
  }
}
