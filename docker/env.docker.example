# Copy to docker/.env and adjust:
#   cp docker/env.docker.example docker/.env
#
# Start stack (production — rebuild après changement de code Next) :
#   docker compose --env-file docker/.env up --build -d
#
# Dev — hot reload, code monté depuis le repo :
#   docker compose --env-file docker/.env -f docker-compose.yml -f docker-compose.dev.yml up --build
#
# TenacitOS: http://localhost:8119  ·  OpenClaw gateway UI: http://localhost:18789

# Required — TenacitOS login
ADMIN_PASSWORD=change-me-strong-password
# openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32

# OpenClaw gateway auth (bind=lan). Must match gateway.auth.token in openclaw.json.
# If you set this, the OpenClaw container overwrites gateway.auth.token on each start
# so `openclaw channels status` and TenacitOS /api/office use the same secret.
# Leave unset to keep the token already stored in the volume (doctor-generated).
# OPENCLAW_GATEWAY_TOKEN=another-long-random-secret

# Optional branding (passed into the tenacitos container)
NEXT_PUBLIC_AGENT_NAME=Mission Control
NEXT_PUBLIC_AGENT_EMOJI=🤖
NEXT_PUBLIC_AGENT_DESCRIPTION=Your AI co-pilot, powered by OpenClaw
NEXT_PUBLIC_APP_TITLE=Mission Control

# WhatsApp — merge au démarrage du conteneur openclaw (merge-whatsapp-channel.cjs)
# Numéros en chiffres uniquement ou +E.164 ; plusieurs valeurs séparées par une virgule.
# OPENCLAW_WHATSAPP_ALLOW_FROM=32496881898
# Retirer de allowFrom / groupAllowFrom (ex. ancien numéro approuvé) :
# OPENCLAW_WHATSAPP_DENYLIST=32471103654
#
# PowerShell — do not type "<CODE>"; use the real pairing code, e.g.:
#   docker compose exec openclaw openclaw pairing approve whatsapp 482193
#
# Optional — POST /api/notify/hello (Réglages → Quick Actions « Hello world »)
# Ne jamais committer l’URL complète du webhook (secret dans le chemin).
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN
# NOTIFY_WHATSAPP_E164=+32496881898

# Modèle par défaut — stack gratuite : Ollama sur la machine hôte (poids ouverts, $0).
# Défaut léger : llama3.2:3b (~2 Go RAM). Encore plus petit : llama3.2:1b ou qwen2.5:0.5b.
# Sur l’hôte :  ollama pull llama3.2:3b  (voir https://docs.openclaw.ai/providers/ollama).
# Linux pur : remplacer host.docker.internal par l’IP du host (ex. http://172.17.0.1:11434).
# OPENCLAW_OLLAMA_BASE_URL=http://host.docker.internal:11434
# OPENCLAW_OLLAMA_MODEL_ID=llama3.2:3b
# OPENCLAW_MODEL_PRIMARY=ollama/llama3.2:3b
# OPENCLAW_OLLAMA_CONTEXT_WINDOW=8192
# OPENCLAW_OLLAMA_MAX_TOKENS=4096
# Modèles plus costauds : glm-4.7-flash, gpt-oss:20b, llama3.3 (ollama pull …)
#
# Revenir à un modèle cloud (clé API requise) :
# OPENCLAW_MODEL_PRIMARY=anthropic/claude-sonnet-4-5

# OpenClaw model keys: https://docs.openclaw.ai/
