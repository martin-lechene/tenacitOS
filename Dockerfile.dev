# TenacitOS — image de développement (source montée depuis l’hôte, pas de rebuild à chaque edit)
# Utilisée avec docker-compose.dev.yml
FROM node:22-bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package.json package-lock.json ./
# node_modules viennent du volume + `npm ci` au premier démarrage (voir entrypoint dev)

COPY data /opt/tenacitos-data-examples
COPY docker/tenacitos-dev-entrypoint.sh /tenacitos-dev-entrypoint.sh
RUN chmod +x /tenacitos-dev-entrypoint.sh

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=development

ENTRYPOINT ["/tenacitos-dev-entrypoint.sh"]
CMD ["npm", "run", "dev", "--", "-p", "3000"]
